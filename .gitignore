# This .gitignore file is automatically generated for Unity projects.

# Unity-generated folders
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/

# MemoryCaptures can get quite large and should be ignored
/[Mm]emoryCaptures/

# Asset OVR logs
/[Aa]ssets/Oculus/VR/Editor/AndroidManifest.OVRSubmission.apk

# Visual Studio / Rider / IDE cache directories
.vs/
.gradle/
.idea/
.rider/
*.suo
*.user
*.userprefs
*.db
*.opendb
*.VC.db

# Autogenerated VS/MD/Consulo solution and project files
*.csproj
*.unityproj
*.sln
*.tmp
*.pidb
*.booproj
*.svd
*.class
*.pdb

# Unity3D generated meta files
/*.pidb.meta
/*.sync.meta

# Unity3D Generated File Groups (meta files of ignored project/solution files)
*.csproj.meta
*.unityproj.meta
*.sln.meta
*.suo.meta
*.tmp.meta
*.user.meta
*.userprefs.meta
*.pidb.meta
*.booproj.meta
*.svd.meta
*.class.meta
*.pdb.meta
*.opendb.meta
*.VC.db.meta

# Crashlytics generated file
crashlytics-build.properties

# Packed Addressables
/[Aa]ssets/[Aa]ddressable[Aa]sset[Ss]ettings/[Aa]ndroid/*
/[Aa]ssets/[Aa]ddressable[Aa]sset[Ss]ettings/[Ww]indows/*
/[Aa]ssets/[Aa]ddressable[Aa]sset[Ss]ettings/[Oo]ther/*

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
